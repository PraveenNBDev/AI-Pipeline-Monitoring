# Required: Your Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Port for the backend server (default: 8000)
PORT=8000

# Optional: Set to "production" in prod
ENV=development
